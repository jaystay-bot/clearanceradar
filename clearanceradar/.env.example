# ===========================================
# ClearanceRadar — Environment Variables
# ===========================================
# Copy this file to .env and fill in real values.
#
# VERCEL (frontend build — add these in Vercel dashboard):
#   All REACT_APP_* variables below must be set in Vercel
#   under Project → Settings → Environment Variables.
#
# API SERVER (backend — set on your server, e.g. Railway/Render):
#   All non-REACT_APP variables below go on the API server only.
# ===========================================


# ── Supabase (frontend — Vercel) ──────────────────────────────
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_PUBLISHABLE_KEY=eyJhbGci...   # anon/public JWT from Supabase dashboard

# ── Supabase (backend — API server) ───────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...                  # service_role JWT from Supabase dashboard

# ── Whop (frontend — Vercel) ──────────────────────────────────
REACT_APP_WHOP_CLIENT_ID=YOUR_WHOP_CLIENT_ID
REACT_APP_WHOP_API_KEY=YOUR_WHOP_API_KEY
REACT_APP_WHOP_REDIRECT_URI=https://clearanceradar.vercel.app/auth/callback

# ── Whop (backend — API server) ───────────────────────────────
WHOP_CLIENT_ID=YOUR_WHOP_CLIENT_ID
WHOP_CLIENT_SECRET=YOUR_WHOP_CLIENT_SECRET
WHOP_PRODUCT_ID=YOUR_WHOP_PRODUCT_ID
WHOP_API_KEY=YOUR_WHOP_API_KEY
WHOP_WEBHOOK_SECRET=YOUR_WHOP_WEBHOOK_SECRET

# ── Firebase (frontend — Vercel) ──────────────────────────────
REACT_APP_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-firebase-project-id
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=000000000000
REACT_APP_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
REACT_APP_FIREBASE_VAPID_KEY=YOUR_FIREBASE_VAPID_KEY

# ── Apify (backend — API server only) ─────────────────────────
APIFY_API_TOKEN=apify_api_...   # from console.apify.com → Settings → Integrations

# ── Email alerts (backend — API server only) ──────────────────
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password   # 16-char Google App Password

# ── Server config (backend — API server only) ─────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://clearanceradar.vercel.app

# ── Admin (backend — API server only) ─────────────────────────
ADMIN_KEY=your_secret_admin_key
